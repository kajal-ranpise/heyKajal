PORT=5000

# MongoDB Atlas connection string
# Local dev:  mongodb://localhost:27017/my-mern-app
# Production: mongodb+srv://<user>:<pass>@cluster.mongodb.net/my-mern-app
MONGO_URI=

JWT_SECRET=

ADMIN_USERNAME=
ADMIN_PASSWORD=

# AWS S3 — create an IAM user with s3:PutObject on the bucket
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
